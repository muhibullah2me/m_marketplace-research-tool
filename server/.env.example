# Rename this file to .env and fill in your real values.
# Get these from your Etsy Developer dashboard: https://www.etsy.com/developers/your-apps

ETSY_KEYSTRING=your_keystring_here
ETSY_SHARED_SECRET=your_shared_secret_here

# Port the backend server runs on (default 3001)
PORT=3001

# The URL your frontend is served from, for CORS.
# When testing locally this is usually http://localhost:5500 or similar.
# When deployed, set this to your real frontend URL.
FRONTEND_ORIGIN=http://localhost:5500
